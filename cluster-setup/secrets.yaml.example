# ==========================================
# K8s Secrets Configuration (EXAMPLE)
# ==========================================
# WARNING: This is just an example. Do not commit secrets.
#
# HOW TO USE:
# 1. Copy this file and rename to secrets.yaml (ignored by git)
# 2. Fill in your MongoDB Atlas connection string below (No Base64 needed due to stringData).
# 3. Apply to GCP: kubectl apply -f secrets.yaml

# ==============================================================================
# 檔案名稱 (File): cluster-setup/secrets.yaml.example
# 負責元件 (Component): 密碼與金鑰管理 (Secrets)
# 檔案用途 (Purpose): 用於展示與說明叢集所需的 K8s Secret 結構 (不含真實密碼，可進版控)。
# 使用方式 (Usage): 複製此檔為 secrets.yaml，填入真實憑證後，手動 apply 進入 K8s。
# ==============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: db-secrets
type: Opaque
stringData:
  DAYNOTE_MONGO_URI: "YOUR_ATLAS_CONNECTION_STRING_HERE"
  PET_MONGODB_URI: "YOUR_ATLAS_CONNECTION_STRING_HERE"
  TIRE_ERP_MONGO_URI: "YOUR_ATLAS_CONNECTION_STRING_HERE"
